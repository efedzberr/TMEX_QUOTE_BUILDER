import { useState } from 'react';
import { Edit2, Trash2, FileText, Plus, Check, X, Truck, ChevronDown } from 'lucide-react';
import { QuoteLane } from '../lib/supabase';

interface QuoteLanesProps {
  lanes: QuoteLane[];
  onUpdateLane: (id: string, updates: Partial<QuoteLane>) => void;
  onAddLane: (newLane: Partial<QuoteLane>) => void;
  onDeleteLane: (id: string) => void;
  onShowDetails: (lane: QuoteLane) => void;
  onGlobalEquipmentTypeChange?: (equipmentType: string) => void;
}

export function QuoteLanes({
  lanes,
  onUpdateLane,
  onAddLane,
  onDeleteLane,
  onShowDetails,
  onGlobalEquipmentTypeChange,
}: QuoteLanesProps) {
  const [editingId, setEditingId] = useState<string | null>(null);
  const [isAdding, setIsAdding] = useState(false);
  const [editData, setEditData] = useState<Partial<QuoteLane>>({});
  const [expandedLane, setExpandedLane] = useState<string | null>(null);
  const [showEquipmentDropdown, setShowEquipmentDropdown] = useState(false);
  const [globalEquipmentType, setGlobalEquipmentType] = useState<string>('Equipment Type');

  const equipmentTypes = [
    'Dry Van',
    'Flatbed',
    'Step Deck',
    'Refrigerated / Reefer',
    'Hazmat',
    'Tanker',
    'Intermodal',
  ];

  const handleGlobalEquipmentChange = (type: string) => {
    setGlobalEquipmentType(type);
    setShowEquipmentDropdown(false);
    if (onGlobalEquipmentTypeChange) {
      onGlobalEquipmentTypeChange(type);
    }
  };

  const calculateTotalRate = (lane: Partial<QuoteLane>) => {
    return (lane.us_rate || 0) + (lane.mx_rate || 0) + (lane.border_crossing_fee || 0);
  };

  const handleEdit = (lane: QuoteLane) => {
    setEditingId(lane.id);
    setEditData(lane);
  };

  const handleSaveEdit = () => {
    if (editingId) {
      onUpdateLane(editingId, editData);
      setEditingId(null);
      setEditData({});
    }
  };

  const handleCancelEdit = () => {
    setEditingId(null);
    setEditData({});
  };

  const handleStartAdd = () => {
    setIsAdding(true);
    setEditData({
      origin_city: '',
      destination_city: '',
      border_crossing: '',
      border_crossing_fee: 0,
      us_rate: 0,
      mx_rate: 0,
      equipment_type: 'Dry Van',
      effective_from_date: '2026-02-01',
      effective_to_date: '2026-12-31',
      units_type: 'Miles',
      currency_type: 'USD',
    });
  };

  const handleSaveAdd = () => {
    onAddLane(editData);
    setIsAdding(false);
    setEditData({});
  };

  const handleCancelAdd = () => {
    setIsAdding(false);
    setEditData({});
  };

  const getEquipmentFields = (equipmentType: string) => {
    switch (equipmentType) {
      case 'Dry Van':
      case 'Hazmat':
        return ['un_number', 'msds'];
      case 'Flat Bed':
      case 'Step Deck':
        return ['weight', 'dimensions', 'invoice_value'];
      case 'Reefer':
      case 'Refrigerated':
        return ['temperature', 'temperature_unit', 'packaging'];
      default:
        return [];
    }
  };

  const renderEditRow = (data: Partial<QuoteLane>, index: number, isNew: boolean = false) => (
    <>
      <tr className="bg-blue-50">
        <td className="px-4 py-3 text-sm text-gray-500">{isNew ? lanes.length + 1 : index + 1}</td>
        <td className="px-2 py-2">
          <input
            type="text"
            value={data.origin_city || ''}
            onChange={(e) => setEditData({ ...data, origin_city: e.target.value })}
            className="w-full px-2 py-1 text-sm border border-gray-300 rounded"
            placeholder="Origin City"
          />
        </td>
        <td className="px-2 py-2">
          <input
            type="text"
            value={data.destination_city || ''}
            onChange={(e) => setEditData({ ...data, destination_city: e.target.value })}
            className="w-full px-2 py-1 text-sm border border-gray-300 rounded"
            placeholder="Destination"
          />
        </td>
        <td className="px-2 py-2">
          <input
            type="text"
            value={data.border_crossing || ''}
            onChange={(e) => setEditData({ ...data, border_crossing: e.target.value })}
            className="w-full px-2 py-1 text-sm border border-gray-300 rounded"
            placeholder="Border"
          />
        </td>
        <td className="px-2 py-2">
          <input
            type="number"
            step="0.01"
            value={data.border_crossing_fee || 0}
            onChange={(e) => setEditData({ ...data, border_crossing_fee: parseFloat(e.target.value) || 0 })}
            className="w-full px-2 py-1 text-sm border border-gray-300 rounded text-right"
          />
        </td>
        <td className="px-2 py-2">
          <input
            type="number"
            step="0.01"
            value={data.us_rate || 0}
            onChange={(e) => setEditData({ ...data, us_rate: parseFloat(e.target.value) || 0 })}
            className="w-full px-2 py-1 text-sm border border-gray-300 rounded text-right"
          />
        </td>
        <td className="px-2 py-2">
          <input
            type="number"
            step="0.01"
            value={data.mx_rate || 0}
            onChange={(e) => setEditData({ ...data, mx_rate: parseFloat(e.target.value) || 0 })}
            className="w-full px-2 py-1 text-sm border border-gray-300 rounded text-right"
          />
        </td>
        <td className="px-4 py-3 text-sm text-gray-900 text-right font-bold">
          ${calculateTotalRate(data).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
        </td>
        <td className="px-2 py-2">
          <select
            value={data.equipment_type || 'Dry Van'}
            onChange={(e) => {
              setEditData({ ...data, equipment_type: e.target.value });
              setExpandedLane(isNew ? 'new' : (data.id || null));
            }}
            className="w-full px-2 py-1 text-sm border border-gray-300 rounded"
          >
            <option value="Dry Van">Dry Van</option>
            <option value="Flatbed">Flatbed</option>
            <option value="Step Deck">Step Deck</option>
            <option value="Refrigerated / Reefer">Refrigerated / Reefer</option>
            <option value="Hazmat">Hazmat</option>
            <option value="Tanker">Tanker</option>
            <option value="Intermodal">Intermodal</option>
          </select>
        </td>
        <td className="px-2 py-2">
          <input
            type="date"
            value={data.effective_from_date || '2026-02-01'}
            onChange={(e) => setEditData({ ...data, effective_from_date: e.target.value })}
            className="w-full px-2 py-1 text-sm border border-gray-300 rounded"
          />
        </td>
        <td className="px-2 py-2">
          <input
            type="date"
            value={data.effective_to_date || '2026-12-31'}
            onChange={(e) => setEditData({ ...data, effective_to_date: e.target.value })}
            className="w-full px-2 py-1 text-sm border border-gray-300 rounded"
          />
        </td>
        <td className="px-4 py-3">
          <div className="flex items-center justify-center gap-1">
            <button
              onClick={isNew ? handleSaveAdd : handleSaveEdit}
              className="p-1.5 text-green-600 hover:bg-green-50 rounded transition-colors"
              title="Save"
            >
              <Check className="w-4 h-4" />
            </button>
            <button
              onClick={isNew ? handleCancelAdd : handleCancelEdit}
              className="p-1.5 text-gray-600 hover:bg-gray-100 rounded transition-colors"
              title="Cancel"
            >
              <X className="w-4 h-4" />
            </button>
          </div>
        </td>
      </tr>
      {expandedLane === (isNew ? 'new' : data.id) && getEquipmentFields(data.equipment_type || '').length > 0 && (
        <tr className="bg-yellow-50">
          <td colSpan={12} className="px-6 py-3">
            <div className="grid grid-cols-4 gap-3">
              {getEquipmentFields(data.equipment_type || '').map((field) => (
                <div key={field}>
                  <label className="block text-xs font-medium text-gray-600 uppercase mb-1">
                    {field.replace('_', ' ')}
                  </label>
                  {field === 'msds' ? (
                    <label className="flex items-center gap-2">
                      <input
                        type="checkbox"
                        checked={data.msds || false}
                        onChange={(e) => setEditData({ ...data, msds: e.target.checked })}
                        className="rounded border-gray-300"
                      />
                      <span className="text-sm">Required</span>
                    </label>
                  ) : field === 'temperature_unit' ? (
                    <select
                      value={data.temperature_unit || 'F'}
                      onChange={(e) => setEditData({ ...data, temperature_unit: e.target.value })}
                      className="w-full px-2 py-1 text-sm border border-gray-300 rounded"
                    >
                      <option value="F">°F</option>
                      <option value="C">°C</option>
                    </select>
                  ) : field === 'packaging' ? (
                    <select
                      value={data.packaging || ''}
                      onChange={(e) => setEditData({ ...data, packaging: e.target.value })}
                      className="w-full px-2 py-1 text-sm border border-gray-300 rounded"
                    >
                      <option value="">Select...</option>
                      <option value="Palletized">Palletized</option>
                      <option value="Loose">Loose</option>
                      <option value="Crated">Crated</option>
                    </select>
                  ) : field === 'invoice_value' ? (
                    <input
                      type="number"
                      step="0.01"
                      value={(data as any)[field] || 0}
                      onChange={(e) => setEditData({ ...data, [field]: parseFloat(e.target.value) || 0 })}
                      className="w-full px-2 py-1 text-sm border border-gray-300 rounded"
                    />
                  ) : (
                    <input
                      type="text"
                      value={(data as any)[field] || ''}
                      onChange={(e) => setEditData({ ...data, [field]: e.target.value })}
                      className="w-full px-2 py-1 text-sm border border-gray-300 rounded"
                    />
                  )}
                </div>
              ))}
            </div>
          </td>
        </tr>
      )}
    </>
  );

  return (
    <div className="bg-white rounded-lg shadow-sm border border-gray-200">
      <div className="px-6 py-4 border-b border-gray-200 flex items-center justify-between">
        <div className="flex items-center gap-3">
          <h2 className="text-lg font-semibold text-gray-900">Quote Lanes</h2>
          <span className="px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-100 text-blue-800">
            {lanes.length} {lanes.length === 1 ? 'lane' : 'lanes'}
          </span>
        </div>
        <div className="flex items-center gap-3">
          <div className="relative">
            <button
              onClick={() => setShowEquipmentDropdown(!showEquipmentDropdown)}
              className="inline-flex items-center gap-2 px-4 py-2 bg-white border border-gray-300 text-gray-700 text-sm font-medium rounded-md hover:bg-gray-50 transition-colors shadow-sm"
            >
              <Truck className="w-4 h-4" />
              <span>{globalEquipmentType}</span>
              <ChevronDown className="w-4 h-4" />
            </button>
            {showEquipmentDropdown && (
              <div className="absolute right-0 mt-2 w-56 bg-white border border-gray-200 rounded-md shadow-lg z-10">
                {equipmentTypes.map((type) => (
                  <button
                    key={type}
                    onClick={() => handleGlobalEquipmentChange(type)}
                    className="block w-full text-left px-4 py-2 text-sm text-gray-700 hover:bg-blue-50 hover:text-blue-600 transition-colors first:rounded-t-md last:rounded-b-md"
                  >
                    {type}
                  </button>
                ))}
              </div>
            )}
          </div>
          <button
            onClick={handleStartAdd}
            disabled={isAdding || editingId !== null}
            className="inline-flex items-center gap-2 px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-md hover:bg-blue-700 transition-colors shadow-sm disabled:opacity-50 disabled:cursor-not-allowed"
          >
            <Plus className="w-4 h-4" />
            New Lane
          </button>
        </div>
      </div>

      <div className="overflow-x-auto">
        <table className="min-w-full divide-y divide-gray-200">
          <thead className="bg-gray-50">
            <tr>
              <th className="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider w-12">#</th>
              <th className="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Origin City</th>
              <th className="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Destination City</th>
              <th className="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Border Crossing</th>
              <th className="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Border Fee</th>
              <th className="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">US Rate</th>
              <th className="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">MX Rate</th>
              <th className="px-4 py-3 text-right text-xs font-semibold text-gray-600 uppercase tracking-wider">Total Rate</th>
              <th className="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Equipment Type</th>
              <th className="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Effective From</th>
              <th className="px-4 py-3 text-left text-xs font-semibold text-gray-600 uppercase tracking-wider">Effective To</th>
              <th className="px-4 py-3 text-center text-xs font-semibold text-gray-600 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody className="bg-white divide-y divide-gray-200">
            {lanes.map((lane, index) => (
              editingId === lane.id ? renderEditRow(editData, index) : (
                <tr key={lane.id} className="hover:bg-gray-50 transition-colors">
                  <td className="px-4 py-3 whitespace-nowrap text-sm text-gray-500">{index + 1}</td>
                  <td className="px-4 py-3 whitespace-nowrap">
                    <a href="#" className="text-sm font-medium text-blue-600 hover:text-blue-800 hover:underline">
                      {lane.origin_city}
                    </a>
                  </td>
                  <td className="px-4 py-3 whitespace-nowrap">
                    <a href="#" className="text-sm font-medium text-blue-600 hover:text-blue-800 hover:underline">
                      {lane.destination_city}
                    </a>
                  </td>
                  <td className="px-4 py-3 whitespace-nowrap text-sm text-gray-900">{lane.border_crossing}</td>
                  <td className="px-4 py-3 whitespace-nowrap text-sm text-gray-900 text-right font-medium">
                    {lane.currency_type === 'MXN' ? 'MX$' : '$'}{lane.border_crossing_fee.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                  </td>
                  <td className="px-4 py-3 whitespace-nowrap text-sm text-gray-900 text-right font-medium">
                    {lane.currency_type === 'MXN' ? 'MX$' : '$'}{lane.us_rate.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                  </td>
                  <td className="px-4 py-3 whitespace-nowrap text-sm text-gray-900 text-right font-medium">
                    {lane.currency_type === 'MXN' ? 'MX$' : '$'}{lane.mx_rate.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                  </td>
                  <td className="px-4 py-3 whitespace-nowrap text-sm text-gray-900 text-right font-bold">
                    {lane.currency_type === 'MXN' ? 'MX$' : '$'}{calculateTotalRate(lane).toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 })}
                  </td>
                  <td className="px-4 py-3 whitespace-nowrap">
                    <span className="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-800">
                      {lane.equipment_type}
                    </span>
                  </td>
                  <td className="px-4 py-3 whitespace-nowrap text-sm text-gray-900">
                    {new Date(lane.effective_from_date).toLocaleDateString('en-US')}
                  </td>
                  <td className="px-4 py-3 whitespace-nowrap text-sm text-gray-900">
                    {new Date(lane.effective_to_date).toLocaleDateString('en-US')}
                  </td>
                  <td className="px-4 py-3 whitespace-nowrap">
                    <div className="flex items-center justify-center gap-1">
                      <button
                        onClick={() => handleEdit(lane)}
                        className="p-1.5 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded transition-colors"
                        title="Edit"
                      >
                        <Edit2 className="w-4 h-4" />
                      </button>
                      <button
                        onClick={() => onDeleteLane(lane.id)}
                        className="p-1.5 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded transition-colors"
                        title="Delete"
                      >
                        <Trash2 className="w-4 h-4" />
                      </button>
                      <button
                        onClick={() => onShowDetails(lane)}
                        className="p-1.5 text-gray-400 hover:text-blue-600 hover:bg-blue-50 rounded transition-colors"
                        title="Additional Details"
                      >
                        <FileText className="w-4 h-4" />
                      </button>
                    </div>
                  </td>
                </tr>
              )
            ))}
            {isAdding && renderEditRow(editData, lanes.length, true)}
          </tbody>
        </table>
      </div>

      {lanes.length === 0 && !isAdding && (
        <div className="px-6 py-12 text-center">
          <div className="text-gray-400 mb-2">
            <FileText className="w-12 h-12 mx-auto" />
          </div>
          <p className="text-sm text-gray-500">No lanes added yet</p>
          <p className="text-xs text-gray-400 mt-1">Click "New Lane" to add your first freight lane</p>
        </div>
      )}
    </div>
  );
}
