                        );
                      })()}

                      {validationErrors.lane1.mx_miles && (
                        <div className="text-xs text-red-500 mt-0.5">{validationErrors.lane1.mx_miles}</div>
                      )}
                    </td>

                    <td className="px-2 py-2">
                        {(() => {
                          const fieldVis = getFieldVisibility(editData.service_type);
                          return ['FLT', 'Flat Rate', '', null].includes(editData.rate_type) ? (
                            <div className="w-20 px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded text-right">
                              {(editData.mx_miles && editData.mx_rate) ? ((editData.mx_rate / editData.mx_miles).toFixed(2)) : '—'}
                            </div>
                          ) : (
                            <>
                              <input type="number" step="0.01" value={fieldVis.mxFieldsDisabled ? 0 : (editData.mx_rate_per_mile || 0)} onChange={(e) => {
                                if (!fieldVis.mxFieldsDisabled) {
                                  setEditData({ ...editData, mx_rate_per_mile: parseFloat(e.target.value) || 0 });
                                  setValidationErrors(prev => ({ ...prev, lane1: { ...prev.lane1, mx_rate_per_mile: '' } }));
                                }
                              }} disabled={fieldVis.mxFieldsDisabled} className={getFieldClassName(fieldVis.mxFieldsDisabled, !!validationErrors.lane1.mx_rate_per_mile)} />
                              {validationErrors.lane1.mx_rate_per_mile && (
                                <div className="text-xs text-red-500 mt-0.5">{validationErrors.lane1.mx_rate_per_mile}</div>
                              )}
                            </>
                          );
                        })()}
                    </td>
                    <td className="px-2 py-2">
                      {(() => {
                        const fieldVis = getFieldVisibility(editData.service_type);
                        return (
                          <input type="number" step="0.01" value={fieldVis.mxFieldsDisabled ? 0 : (editData.mx_fuel_rate || 0)} onChange={(e) => {
                            if (!fieldVis.mxFieldsDisabled) setEditData({ ...editData, mx_fuel_rate: parseFloat(e.target.value) || 0 });
                          }} disabled={fieldVis.mxFieldsDisabled} className={getFieldClassName(fieldVis.mxFieldsDisabled, false)} />
                        );
                      })()}
                    </td>
                    <td className="px-2 py-2"><select value={editData.lane_type || ''} onChange={(e) => setEditData({ ...editData, lane_type: e.target.value })} className="w-24 px-2 py-1 text-xs border rounded"><option value="">Select</option>{LANE_TYPES.map(t => <option key={t} value={t}>{t}</option>)}</select></td>
                    <td className="px-2 py-2"><select value={editData.trip_type || 'One Way'} onChange={(e) => setEditData({ ...editData, trip_type: e.target.value })} className="w-24 px-2 py-1 text-xs border rounded">{TRIP_TYPES.map(t => <option key={t} value={t}>{t}</option>)}</select></td>
                    <td className="px-2 py-2"><select value={editData.equipment_type || 'Dry Van'} onChange={(e) => setEditData({ ...editData, equipment_type: e.target.value })} className="w-24 px-2 py-1 text-xs border rounded">{EQUIPMENT_TYPES.map(t => <option key={t} value={t}>{t}</option>)}</select></td>
                    <td className="px-2 py-2"><input type="number" value={editData.load_volume || ''} onChange={(e) => setEditData({ ...editData, load_volume: e.target.value })} className="w-20 px-2 py-1 text-xs border rounded text-right" /></td>
                    <td className="px-2 py-2"><select value={editData.load_frequency || ''} onChange={(e) => setEditData({ ...editData, load_frequency: e.target.value })} className="w-24 px-2 py-1 text-xs border rounded"><option value="">Select</option>{LOAD_FREQUENCIES.map(f => <option key={f} value={f}>{f}</option>)}</select></td>
                    <td className="px-2 py-2"><input type="date" value={editData.effective_from_date || '2026-02-01'} onChange={(e) => setEditData({ ...editData, effective_from_date: e.target.value })} className="w-28 px-2 py-1 text-xs border rounded" /></td>
                    <td className="px-2 py-2"><input type="date" value={editData.effective_to_date || '2026-12-31'} onChange={(e) => setEditData({ ...editData, effective_to_date: e.target.value })} className="w-28 px-2 py-1 text-xs border rounded" /></td>
                    <td className="px-3 py-3">{selectedTripType === 'One Way' && <div className="flex gap-1"><button onClick={handleSaveAdd} className="p-1 text-green-600 hover:bg-green-50 rounded"><Check className="w-3 h-3" /></button><button onClick={handleCancelAdd} className="p-1 text-gray-600 hover:bg-gray-100 rounded"><X className="w-3 h-3" /></button></div>}</td>
                  </tr>

                  {(selectedTripType === 'Round Trip' || selectedTripType === 'Circuit') && (
                    <tr className={`bg-green-50 ${selectedTripType === 'Round Trip' ? 'border-l-4 border-l-green-400' : 'border-l-4 border-l-orange-400'}`}>
                      <td className="px-3 py-3 text-sm text-gray-500">
                        <div className="flex items-center gap-2">
                          <span>{lanes.length + 2}</span>
                          <span className={`inline-flex items-center gap-1 px-1.5 py-0.5 rounded text-xs font-semibold ${
                            selectedTripType === 'Round Trip' ? 'bg-green-100 text-green-700' : 'bg-orange-100 text-orange-700'
                          }`}>
                            <Link2 className="w-3 h-3" />
                            {selectedTripType === 'Round Trip' ? 'RT' : 'CIR'}
                          </span>
                        </div>
                      </td>
                      <td className="px-2 py-2">
                        {selectedTripType === 'Round Trip' ? (
                          <div className="bg-gray-100 italic text-xs text-gray-700 px-2 py-1 rounded border">{editData2.origin_city || 'Auto'}</div>
                        ) : (
                          <CityAutocompleteInput value={editData2.origin_city || ''} onChange={(value) => setEditData2({ ...editData2, origin_city: value })} className="w-32 px-2 py-1 text-xs border rounded" placeholder="Origin" />
                        )}
                      </td>
                      <td className="px-2 py-2">
                        {selectedTripType === 'Round Trip' ? (
                          <div className="bg-gray-100 italic text-xs text-gray-700 px-2 py-1 rounded border">{editData2.destination_city || 'Auto'}</div>
                        ) : (
                          <CityAutocompleteInput value={editData2.destination_city || ''} onChange={(value) => setEditData2({ ...editData2, destination_city: value })} className="w-32 px-2 py-1 text-xs border rounded" placeholder="Destination" />
                        )}
                      </td>
                      <td className="px-2 py-2">
                        <div className="bg-gray-100 italic text-xs text-gray-700 px-2 py-1 rounded border">{editData2.border_crossing || 'Auto'}</div>
                      </td>
                      <td className="px-2 py-2"><input type="number" step="0.01" value={editData2.border_crossing_fee || 0} onChange={(e) => setEditData2({ ...editData2, border_crossing_fee: parseFloat(e.target.value) || 0 })} className="w-20 px-2 py-1 text-xs border rounded text-right" /></td>
                      <td className="px-3 py-3 text-xs font-bold">${calculateTotalRate(editData2).toFixed(2)}</td>
                      <td className="px-2 py-2"><select value={editData2.rate_type || 'FLT'} onChange={(e) => setEditData2({ ...editData2, rate_type: e.target.value })} className="w-16 px-2 py-1 text-xs border rounded">{RATE_TYPES.map(t => <option key={t} value={t}>{t}</option>)}</select></td>
                      <td className="px-2 py-2">
                        {['FLT', 'Flat Rate', '', null].includes(editData2.rate_type) ? (
                          <input type="number" step="0.01" value={editData2.us_rate || 0} onChange={(e) => setEditData2({ ...editData2, us_rate: parseFloat(e.target.value) || 0 })} className="w-20 px-2 py-1 text-xs border rounded text-right" />
                        ) : (
                          <div className="w-20 px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded text-right">
                            {(editData2.us_miles && editData2.us_rate_per_mile) ? ((editData2.us_miles * editData2.us_rate_per_mile).toFixed(2)) : '—'}
                          </div>
                        )}
                      </td>
                      <td className="px-2 py-2"><input type="number" step="0.01" value={editData2.us_miles || 0} onChange={(e) => setEditData2({ ...editData2, us_miles: parseFloat(e.target.value) || 0 })} className="w-20 px-2 py-1 text-xs border rounded text-right" /></td>
                      <td className="px-2 py-2">
                        {['FLT', 'Flat Rate', '', null].includes(editData2.rate_type) ? (
                          <div className="w-20 px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded text-right">
                            {(editData2.us_miles && editData2.us_rate) ? ((editData2.us_rate / editData2.us_miles).toFixed(2)) : '—'}
                          </div>
                        ) : (
                          <input type="number" step="0.01" value={editData2.us_rate_per_mile || 0} onChange={(e) => setEditData2({ ...editData2, us_rate_per_mile: parseFloat(e.target.value) || 0 })} className="w-20 px-2 py-1 text-xs border rounded text-right" />
                        )}
                      </td>
                      <td className="px-2 py-2"><input type="number" step="0.01" value={editData2.us_fuel_rate || 0} onChange={(e) => setEditData2({ ...editData2, us_fuel_rate: parseFloat(e.target.value) || 0 })} className="w-20 px-2 py-1 text-xs border rounded text-right" /></td>
                      <td className="px-2 py-2">
                        {['FLT', 'Flat Rate', '', null].includes(editData2.rate_type) ? (
                          <input type="number" step="0.01" value={editData2.mx_rate || 0} onChange={(e) => setEditData2({ ...editData2, mx_rate: parseFloat(e.target.value) || 0 })} className="w-20 px-2 py-1 text-xs border rounded text-right" />
                        ) : (
                          <div className="w-20 px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded text-right">
                            {(editData2.mx_miles && editData2.mx_rate_per_mile) ? ((editData2.mx_miles * editData2.mx_rate_per_mile).toFixed(2)) : '—'}
                          </div>
                        )}
                      </td>
                      <td className="px-2 py-2"><input type="number" step="0.01" value={editData2.mx_miles || 0} onChange={(e) => setEditData2({ ...editData2, mx_miles: parseFloat(e.target.value) || 0 })} className="w-20 px-2 py-1 text-xs border rounded text-right" /></td>
                      <td className="px-2 py-2">
                        {['FLT', 'Flat Rate', '', null].includes(editData2.rate_type) ? (
                          <div className="w-20 px-2 py-1 text-xs bg-gray-100 text-gray-700 rounded text-right">
                            {(editData2.mx_miles && editData2.mx_rate) ? ((editData2.mx_rate / editData2.mx_miles).toFixed(2)) : '—'}
                          </div>
                        ) : (
                          <input type="number" step="0.01" value={editData2.mx_rate_per_mile || 0} onChange={(e) => setEditData2({ ...editData2, mx_rate_per_mile: parseFloat(e.target.value) || 0 })} className="w-20 px-2 py-1 text-xs border rounded text-right" />
                        )}
                      </td>
                      <td className="px-2 py-2"><input type="number" step="0.01" value={editData2.mx_fuel_rate || 0} onChange={(e) => setEditData2({ ...editData2, mx_fuel_rate: parseFloat(e.target.value) || 0 })} className="w-20 px-2 py-1 text-xs border rounded text-right" /></td>
                      <td className="px-2 py-2"><select value={editData2.lane_type || ''} onChange={(e) => setEditData2({ ...editData2, lane_type: e.target.value })} className="w-24 px-2 py-1 text-xs border rounded"><option value="">Select</option>{LANE_TYPES.map(t => <option key={t} value={t}>{t}</option>)}</select></td>
                      <td className="px-2 py-2"><select value={editData2.trip_type || selectedTripType} onChange={(e) => setEditData2({ ...editData2, trip_type: e.target.value })} className="w-24 px-2 py-1 text-xs border rounded">{TRIP_TYPES.map(t => <option key={t} value={t}>{t}</option>)}</select></td>
                      <td className="px-2 py-2"><select value={editData2.equipment_type || 'Dry Van'} onChange={(e) => setEditData2({ ...editData2, equipment_type: e.target.value })} className="w-24 px-2 py-1 text-xs border rounded">{EQUIPMENT_TYPES.map(t => <option key={t} value={t}>{t}</option>)}</select></td>
                      <td className="px-2 py-2"><input type="number" value={editData2.load_volume || ''} onChange={(e) => setEditData2({ ...editData2, load_volume: e.target.value })} className="w-20 px-2 py-1 text-xs border rounded text-right" /></td>
                      <td className="px-2 py-2"><select value={editData2.load_frequency || ''} onChange={(e) => setEditData2({ ...editData2, load_frequency: e.target.value })} className="w-24 px-2 py-1 text-xs border rounded"><option value="">Select</option>{LOAD_FREQUENCIES.map(f => <option key={f} value={f}>{f}</option>)}</select></td>
                      <td className="px-2 py-2"><input type="date" value={editData2.effective_from_date || '2026-02-01'} onChange={(e) => setEditData2({ ...editData2, effective_from_date: e.target.value })} className="w-28 px-2 py-1 text-xs border rounded" /></td>
                      <td className="px-2 py-2"><input type="date" value={editData2.effective_to_date || '2026-12-31'} onChange={(e) => setEditData2({ ...editData2, effective_to_date: e.target.value })} className="w-28 px-2 py-1 text-xs border rounded" /></td>
                      <td className="px-3 py-3">
                        <div className="flex gap-1">
                          <button onClick={handleSaveAdd} className="p-1 text-green-600 hover:bg-green-50 rounded"><Check className="w-3 h-3" /></button>
                          <button onClick={handleCancelAdd} className="p-1 text-gray-600 hover:bg-gray-100 rounded"><X className="w-3 h-3" /></button>
                        </div>
                      </td>
                    </tr>
                  )}
                  </>
                )}
              </tbody>
            </table>
          </div>
        )}
      </div>

      {lanes.length === 0 && !isAdding && (
        <div className="px-6 py-12 text-center">
          <div className="text-gray-400 mb-2">
            <FileText className="w-12 h-12 mx-auto" />
          </div>
          <p className="text-sm text-gray-500">No lanes added yet</p>
          <p className="text-xs text-gray-400 mt-1">Click "New Lane" to add your first freight lane</p>
        </div>
      )}

      {showDeleteConfirm && (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
          <div className="bg-white rounded-lg shadow-xl max-w-md w-full mx-4 p-6">
            {showDeleteConfirm.linkedLaneId === 'lane2-only' ? (
              <>
                <h3 className="text-lg font-semibold text-gray-900 mb-2">Cannot Delete Lane 2</h3>
                <p className="text-sm text-gray-600 mb-6">
                  Lane 2 is part of a paired trip and cannot be deleted independently. Please delete Lane 1 to remove the entire pair.
                </p>
                <div className="flex justify-end">
                  <button
                    onClick={() => setShowDeleteConfirm(null)}
                    className="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200 transition-colors"
                  >
                    OK
                  </button>
                </div>
              </>
            ) : (
              <>
                <h3 className="text-lg font-semibold text-gray-900 mb-2">Delete Paired Lanes</h3>
                <p className="text-sm text-gray-600 mb-6">
                  Deleting Lane 1 will also delete the paired Lane 2. Do you want to delete both lanes?
                </p>
                <div className="flex justify-end gap-3">
                  <button
                    onClick={() => setShowDeleteConfirm(null)}
                    className="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200 transition-colors"
                  >
                    Cancel
                  </button>
                  <button
                    onClick={handleConfirmDelete}
                    className="px-4 py-2 text-sm font-medium text-white bg-red-600 rounded-md hover:bg-red-700 transition-colors"
                  >
                    Delete Both
                  </button>
                </div>
              </>
            )}
          </div>
        </div>
      )}

      {showDuplicateConfirm && (
        <div className="fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
          <div className="bg-white rounded-lg shadow-xl max-w-md w-full mx-4 p-6">
            <h3 className="text-lg font-semibold text-gray-900 mb-2">Duplicate Linked Lane</h3>
            <p className="text-sm text-gray-600 mb-6">
              This lane is part of a linked pair. Duplicating it will create a standalone copy without the {showDuplicateConfirm.trip_type} link. Do you want to proceed?
            </p>
            <div className="flex justify-end gap-3">
              <button
                onClick={() => setShowDuplicateConfirm(null)}
                className="px-4 py-2 text-sm font-medium text-gray-700 bg-gray-100 rounded-md hover:bg-gray-200 transition-colors"
              >
                Cancel
              </button>
              <button
                onClick={handleConfirmDuplicate}
                className="px-4 py-2 text-sm font-medium text-white bg-green-600 rounded-md hover:bg-green-700 transition-colors"
              >
                Duplicate as One Way
              </button>
            </div>
          </div>
        </div>
      )}

      {showServiceTypeModal && (
        <ServiceTypeModal
          onSelect={handleServiceTypeSelect}
          onClose={() => setShowServiceTypeModal(false)}
        />
      )}

      {showTripTypeModal && (
        <TripTypeModal
          onSelect={handleTripTypeSelect}
          onClose={() => setShowTripTypeModal(false)}
          onBack={() => {
            setShowTripTypeModal(false);
            setShowServiceTypeModal(true);
          }}
          serviceType={selectedServiceType}
        />
      )}

    </div>
  );
}
